# ─── Supabase (self-hosted at api.b0ase.com, shared with bmovies.online) ───
NEXT_PUBLIC_SUPABASE_URL=https://api.b0ase.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── xAI Grok (text + image + video generation) ───
XAI_API_KEY=

# ─── Stripe (live keys — same as bmovies.online) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── HandCash (optional wallet provider) ───
HANDCASH_APP_ID=
HANDCASH_APP_SECRET=

# ─── bMovies producer WIF (server-side only, for on-chain mints from app) ───
# Never expose this to the client. Same WIF used by the feature-worker
# on Hetzner. Rotated via scripts/rotate-producer-wif.ts in the bmovies repo.
PRODUCER_WIF=

# ─── Site config ───
NEXT_PUBLIC_SITE_URL=https://app.bmovies.online
NEXT_PUBLIC_MARKETING_URL=https://bmovies.online
